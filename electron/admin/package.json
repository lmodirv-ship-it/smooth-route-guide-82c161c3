{
  "name": "hn-admin-desktop",
  "version": "1.0.0",
  "description": "HN Driver Admin Desktop (Windows OTA)",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never"
  },
  "build": {
    "appId": "company.hndriver.admin",
    "productName": "HN Admin",
    "files": ["main.cjs", "icon.ico", "package.json"],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://www.hndriver.company/downloads/desktop/admin/"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.0",
    "electron-log": "^5.1.0"
  }
}
