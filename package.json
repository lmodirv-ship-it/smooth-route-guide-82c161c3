{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "preinstall": "node -e \"if(process.env.npm_execpath && !process.env.npm_execpath.includes('pnpm')){console.error('\\x1b[31m✖ Please use pnpm to install dependencies.\\x1b[0m');process.exit(1)}\"",
    "start": "vite",
    "dev": "vite",
    "dev:admin": "vite --config vite.config.admin.ts --port 5174",
    "build": "vite build",
    "build:admin": "vite build --config vite.config.admin.ts",
    "build:client": "vite build --config vite.config.client.ts",
    "build:driver-ride": "vite build --config vite.config.driver-ride.ts",
    "build:driver-delivery": "vite build --config vite.config.driver-delivery.ts",
    "build:hn-stock": "vite build --config vite.config.hn-stock.ts",
    "build:all-apps": "pnpm build && pnpm build:admin && pnpm build:client && pnpm build:driver-ride && pnpm build:driver-delivery && pnpm build:hn-stock",
    "build:dev": "vite build --mode development",
    "build:native": "vite build && cap sync",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "pnpm dlx playwright install --with-deps chromium",
    "bootstrap": "pnpm install && echo '✅ Ready! Run: pnpm dev'",
    "mobile:sync": "cap sync",
    "mobile:android": "cap open android",
    "mobile:ios": "cap open ios",
    "native:android": "vite build && cap sync android",
    "native:android:apk": "vite build && cap sync android && cap open android",
    "native:ios": "vite build && cap sync ios",
    "desktop:dist": "vite build && electron-builder",
    "desktop:win": "vite build && electron-builder --win",
    "desktop:mac": "vite build && electron-builder --mac",
    "desktop:linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@hookform/resolvers": "^3.10.0",
